{
  "name": "bug-report-form",
  "version": "1.0.0",
  "description": "Bug report form → Google Docs per sprint, deployed on Vercel",
  "type": "commonjs",
  "scripts": {
    "dev": "node -r ts-node/register server.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "deploy": "vercel --prod"
  },
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "@vercel/node": "^5.6.18",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
