{
  "version": 2,
  "builds": [
    {
      "src": "api/*.ts",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/submit",
      "dest": "/api/submit"
    },
    {
      "src": "/api/bugs",
      "dest": "/api/bugs"
    },
    {
      "src": "/api/update",
      "dest": "/api/update"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}